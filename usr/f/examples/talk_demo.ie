# Speech-to-text demo (macOS only; requires microphone + Speech Recognition permission).
#   export SHAKTI_LIB=$PWD/src/lib
#   ./shakti examples/talk_demo.ie

import talk

talk.set_locale("en-US")
print("talk — speak, then pause ~2s, press Enter, or click to finish")

text : talk.listen(2)
print("transcript:", text)
